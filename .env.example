# -----------------------------------------------------------------------------
# MedMinder AI — copy to `.env.local` (or `.env`) and fill in. No secrets here.
# Full semantics: README → "Environment variables".
# -----------------------------------------------------------------------------

# --- Supabase: project URL + anon key (Next.js reads NEXT_PUBLIC_* at runtime) ---
# Supabase Dashboard → Project Settings → API → "Project URL" (same value you may keep as SUPABASE_URL for CLI).
NEXT_PUBLIC_SUPABASE_URL=
# Same screen → "anon" / "public" key under Project API keys (safe with RLS; never use service_role in the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional naming for CI/Vercel: next.config.mjs maps these to NEXT_PUBLIC_* at build if you prefer non-public env names in the dashboard.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# --- Database URL (CLI / migrations / external tools only; not used by src/ Next app) ---
# Supabase Dashboard → Project Settings → Database → Connection string → URI (pooler often port 6543).
# Pick "Session" vs "Transaction" mode to match your client (CLI/migrations vs serverless); same settings screen.
# DATABASE_URL=

# --- Supabase service role (server/admin scripts only; never NEXT_PUBLIC_ or client code) ---
# Dashboard → Project Settings → API → "service_role" secret key.
# SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI: prescription vision (server-only Server Action) ---
# OpenAI Platform → API keys → Create secret key; restrict by project if available.
OPENAI_API_KEY=

# --- openFDA (optional; higher quota when set) ---
# open.fda.gov → Account / API key (optional for Drug Label API).
OPENFDA_API_KEY=

# --- Web Push / VAPID (RFC 8292) ---
# Generate key pair (e.g. `npx web-push generate-vapid-keys`): public → browser + NEXT_PUBLIC_, private → server only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional: server action also accepts this name for the public key if you do not use NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# VAPID_PUBLIC_KEY=
# Contact for push operator (mailto: or https: URL); some hosts require a real address.
VAPID_SUBJECT=mailto:support@example.com

# --- Smoke tests & guarded routes ---
# Any strong random string; set the same value in Vercel → Environment Variables for Production when using prod-smoke + /api/smoke/payload.
SMOKE_TEST_SECRET=
# Vercel env: set "true" only if you intentionally need /test-db on a deployed build (middleware); default unset in production.
ENABLE_TEST_DB=

# --- Deployment / smoke script base URL ---
# Vercel → Project → Settings → Domains (production URL), or your custom domain — used by `scripts/prod-smoke.mjs` (NEXT_PUBLIC_BASE_URL or BASE_URL).
NEXT_PUBLIC_BASE_URL=
# BASE_URL=

# If Deployment Protection is on: Project → Settings → Deployment Protection → Protection Bypass for Automation (copy that secret into `.env` or `.env.local` for `npm run smoke:prod`).
# VERCEL_AUTOMATION_BYPASS_SECRET=
